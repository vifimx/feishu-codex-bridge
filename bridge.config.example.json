{
  "protocol_version": "2",
  "machine_id": "my-codex-machine",
  "codex": {
    "home_dir": ""
  },
  "log_dir": "C:\\Users\\YOUR_USER\\.codex\\logs\\feishu-codex-bridge",
  "state_dir": "C:\\Users\\YOUR_USER\\.codex\\tmp\\feishu-codex-bridge",
  "workspaces": {
    "default": "C:\\path\\to\\workspace"
  },
  "skills": {
    "available": [
      "feishu",
      "lark-im",
      "lark-event",
      "lark-doc",
      "lark-base",
      "lark-sheets",
      "lark-calendar",
      "lark-task",
      "lark-wiki",
      "lark-drive",
      "lark-minutes",
      "feishu-codex-bridge"
    ]
  },
  "assistant": {
    "display_name": "飞书助手",
    "identity_prompt": "你是飞书助手，一个运行在飞书/Lark聊天里的工作助手。直接、简洁地回答用户问题。",
    "hide_internal_identity": true
  },
  "models": {
    "available": [
      {
        "id": "gpt-5.4",
        "label": "gpt-5.4",
        "reasoning_efforts": [
          "low",
          "medium",
          "high",
          "xhigh"
        ]
      },
      {
        "id": "gpt-5.4-mini",
        "label": "gpt-5.4-mini",
        "reasoning_efforts": [
          "low",
          "medium",
          "high",
          "xhigh"
        ]
      }
    ],
    "default": {
      "model": "gpt-5.4",
      "reasoning_effort": "medium",
      "service_tier": "fast"
    },
    "fast": {
      "model": "gpt-5.4-mini",
      "reasoning_effort": "low",
      "service_tier": "fast"
    }
  },
  "access": {
    "default_policy": {
      "allow_codex": false,
      "unrestricted": false,
      "tasks": [],
      "skills": [],
      "models": []
    },
    "default_template": "no-access",
    "identities": {
      "admin": {
        "label": "Admin User",
        "open_ids": [
          "ou_admin_xxx"
        ],
        "emails": [
          "admin@example.com"
        ],
        "aliases": [
          "admin"
        ],
        "allow_codex": true,
        "unrestricted": true,
        "tasks": [
          "*"
        ],
        "skills": [
          "*"
        ],
        "models": [
          "*"
        ],
        "permission_preset": "user_group:admin"
      },
      "reviewer": {
        "label": "Reviewer",
        "open_ids": [
          "ou_limited_xxx"
        ],
        "emails": [
          "reviewer@example.com"
        ],
        "aliases": [
          "reviewer"
        ],
        "allow_codex": false,
        "unrestricted": false,
        "tasks": [
          "mobile-review"
        ],
        "skills": [],
        "models": [],
        "permission_preset": "user_group:mobile-review"
      }
    },
    "user_groups": {
      "no-access": {
        "label": "No Access",
        "enabled": true,
        "preset_only": true,
        "allow_codex": false,
        "unrestricted": false,
        "tasks": [],
        "skills": [],
        "models": []
      },
      "admin": {
        "label": "Admin",
        "enabled": true,
        "preset_only": true,
        "allow_codex": true,
        "unrestricted": true,
        "tasks": [
          "*"
        ],
        "skills": [
          "*"
        ],
        "models": [
          "*"
        ]
      },
      "mobile-review": {
        "label": "Mobile Review",
        "enabled": true,
        "preset_only": true,
        "allow_codex": false,
        "unrestricted": false,
        "tasks": [
          "mobile-review"
        ],
        "skills": [],
        "models": []
      }
    },
    "groups": {
      "botx-test": {
        "label": "botx test group",
        "chat_ids": [
          "oc_group_xxx"
        ],
        "enabled": true,
        "members": [
          "admin",
          "reviewer"
        ],
        "allow_codex": true,
        "unrestricted": false,
        "show_details": false,
        "show_progress": false,
        "tasks": [
          "mobile-review"
        ],
        "skills": [
          "feishu",
          "lark-doc",
          "lark-base",
          "lark-sheets",
          "lark-calendar",
          "lark-task",
          "lark-wiki",
          "lark-drive",
          "lark-minutes"
        ],
        "models": [
          "gpt-5.4",
          "gpt-5.4-mini"
        ]
      }
    },
    "resolve_contacts_enabled": false,
    "contact_cache_ttl_sec": 86400,
    "enable_preset_intent_matching": true,
    "deny_message": "No permission."
  },
  "capabilities": {
    "modalities": [
      "text",
      "image",
      "file",
      "audio",
      "video"
    ],
    "skills": [
      "feishu",
      "lark-im",
      "lark-event",
      "lark-doc",
      "lark-base",
      "lark-sheets",
      "lark-calendar",
      "lark-task",
      "lark-wiki",
      "lark-drive",
      "lark-minutes",
      "feishu-codex-bridge"
    ],
    "notes": [
      "Text is transported as UTF-8 plain text.",
      "Incoming image/file/audio/video resources are downloaded to local artifact paths when lark-cli can access the message resource.",
      "Codex jobs run through the local codex CLI and keep session files under the local CODEX_HOME."
    ]
  },
  "onboarding": {
    "enabled": true
  },
  "private": {
    "enabled": true,
    "allowed_sender_open_ids": [
      "ou_xxx"
    ],
    "allowed_chat_ids": [
      "oc_xxx"
    ],
    "default_workspace": "default",
    "codex_sandbox": "workspace-write",
    "codex_timeout_sec": 900,
    "codex_active_output_grace_sec": 300,
    "codex_timeout_extension_sec": 300,
    "final_output_ready_sec": 3,
    "final_output_idle_grace_sec": 45,
    "codex_model": "",
    "polling_fallback_enabled": false,
    "poll_interval_sec": 5,
    "treat_all_text_as_codex": true,
    "coalesce_forward_comment_enabled": true,
    "coalesce_forward_comment_window_sec": 1.5
  },
  "public": {
    "enabled": true,
    "allowed_chat_ids": [
      "oc_xxx"
    ],
    "allowed_sender_open_ids": [
      "ou_xxx"
    ],
    "allow_codex": true,
    "treat_all_text_as_codex": false
  },
  "preset_tasks": {
    "mobile-review": {
      "enabled": true,
      "description": "Mobile technical-design review: track review results, manage review documents, and handle review reminder requests.",
      "aliases": [
        "mobile-review",
        "移动端评审",
        "移动端技术方案评审",
        "评审更新",
        "更新评审",
        "新增评审文档",
        "修改评审文档",
        "删除评审文档",
        "评审提醒"
      ],
      "workspace": "default",
      "background": "Mobile technical-design review task collection. Reject unrelated requests.",
      "scope": {
        "allowed": [
          "track mobile review status",
          "manage mobile review documents",
          "send mobile review reminders"
        ],
        "reject": "Reject requests outside mobile technical-design review."
      },
      "references": {
        "tracking_base": {
          "name": "移动端技术方案评审记录多维表格",
          "url": "https://your-domain.feishu.cn/wiki/REVIEW_TRACKING_BASE?table=tbl_xxx&view=vew_xxx"
        }
      },
      "review_schedule": {
        "timezone": "Asia/Shanghai",
        "weekdays": [
          "tue",
          "thu"
        ],
        "start_time": "14:00",
        "end_time": "16:00"
      },
      "knowledge_bases": {
        "RN": "https://your-domain.feishu.cn/wiki/RN_KNOWLEDGE_BASE",
        "Android": "https://your-domain.feishu.cn/wiki/ANDROID_KNOWLEDGE_BASE",
        "iOS": "https://your-domain.feishu.cn/wiki/IOS_KNOWLEDGE_BASE"
      },
      "required_skills": [
        "feishu",
        "lark-im",
        "lark-doc",
        "lark-base",
        "lark-sheets",
        "lark-calendar",
        "lark-task",
        "lark-wiki",
        "lark-drive",
        "lark-minutes"
      ],
      "subtasks": [
        {
          "id": "track-review-result",
          "type": "manual",
          "enabled": true,
          "label": "Track review results",
          "aliases": [
            "评审结果",
            "更新评审状态"
          ],
          "description": "Track review results and create follow-up records for leftovers.",
          "prompt": "Use meeting notes/video and the tracking Base to verify the review result before writing."
        },
        {
          "id": "manage-review-doc",
          "type": "manual",
          "enabled": true,
          "label": "Manage review documents",
          "aliases": [
            "新增评审文档",
            "修改评审文档",
            "删除评审文档"
          ],
          "description": "Add, modify, or delete review documents after duplicate/readability/knowledge-base checks.",
          "prompt": "Check duplicates, document readability, and knowledge-base placement before updating the tracking Base. Do not assume a /wiki URL is already in the expected review knowledge base; first resolve it with lark-cli wiki spaces get_node and compare its space_id/parent_node_token with the configured target. If the source is already a Wiki node, move it with wiki +move --node-token <source_node_token> to the target space or parent; do not use --obj-type/--obj-token docs_to_wiki mode for an existing Wiki node. Use wiki +move --obj-type <type> --obj-token <token> --target-space-id <space_id> --apply only when the source is still a Drive document. Creating a copy is the final fallback only after the proper wiki +move path or move request is confirmed impossible and the user confirms; never treat one permission failure as enough reason to create a copy. After moving or submitting a move request, verify the final node location before writing the tracking Base."
        },
        {
          "id": "submit-lock-reminder",
          "type": "automatic",
          "enabled": true,
          "label": "Submit lock reminder",
          "description": "Send the pre-review-day submit reminder without @all.",
          "schedule": {
            "weekdays": [
              "mon",
              "wed"
            ],
            "time": "18:00",
            "catch_up_minutes": 5
          },
          "action": {
            "input": "自动提醒提交：请在当前群发送提醒“即将锁定明天待评审文档，有待评审文档请及时提交”。不要 @任何人，不要 @所有人。",
            "suppress_noop_reply": false,
            "notify_completion": false
          }
        },
        {
          "id": "overload-check",
          "type": "automatic",
          "enabled": true,
          "label": "Overload check",
          "description": "Check same-day overload and only remind when non-leftover new docs exceed 6.",
          "schedule": {
            "weekdays": [
              "tue",
              "thu"
            ],
            "time": "10:00",
            "catch_up_minutes": 5
          },
          "action": {
            "input": "自动提醒超额：请检查今天待评审且非遗留项的新评审文档数量是否超过 6 个。如果超过则提醒当前群；否则只回复“无需提醒”。不要 @任何人，不要 @所有人。",
            "suppress_noop_reply": true,
            "notify_completion": false
          }
        }
      ],
      "output_expectations": "Only handle mobile-review content. Reject unrelated requests. Before writing Feishu Base records, verify the tracking record, notes/video links, and any ambiguous user intent.",
      "prompt_template": "Only execute the mobile technical-design review parent task. Reject unrelated content.\\n\\nTask config:\\n{task_context}\\n\\nSubtasks:\\n{subtasks}\\n\\nSelected subtask:\\n{selected_subtask}\\n\\nSelected subtask instructions:\\n{subtask_prompt}\\n\\nAsk before unsafe writes.\\n\\nRequired skills: {required_skills}\\nTask description: {description}\\nOutput expectations: {output_expectations}\\n\\nUser input:\\n{input}\\n"
    }
  },
  "task_scheduler": {
    "enabled": false,
    "timezone": "Asia/Shanghai",
    "poll_interval_sec": 30
  },
  "jobs": {
    "max_concurrent": 1,
    "history_limit": 200,
    "auto_cleanup_enabled": true,
    "cleanup_delete_artifacts": true
  },
  "reply": {
    "max_chars": 3500,
    "upload_full_output_file": true,
    "edit_status_message": true,
    "show_details_by_default": false,
    "show_progress_by_default": false,
    "progress_max_lines": 8,
    "status_update_interval_sec": 10
  },
  "sessions": {
    "enabled": true,
    "mode": "continuous",
    "private_scope": "chat",
    "group_scope": "chat",
    "continue_after_completion": true,
    "queue_while_running": true,
    "reply_guidance_enabled": true,
    "topic_reply_in_thread": true
  },
  "multimodal": {
    "download_incoming": true,
    "download_timeout_sec": 300,
    "artifact_retention_days": 14
  },
  "routing": {
    "accept_any_target": false,
    "only_respond_to_bot_mention": true,
    "private_only_respond_to_bot_mention": false,
    "bot_mention_names": [
      "飞书助手",
      "my-codex-machine"
    ],
    "dispatch_to_peers": false,
    "prefer_local_when_capable": true
  },
  "health_server": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765
  },
  "dashboard": {
    "allow_config_write": true,
    "allow_process_control": true,
    "allow_shell_integration": true,
    "auto_refresh_sec": 5
  },
  "peers": {
    "enabled": false,
    "nodes": []
  },
  "event_types": [
    "im.chat.access_event.bot_p2p_chat_entered_v1",
    "im.message.bot_muted_v1",
    "im.message.message_read_v1",
    "im.message.recalled_v1",
    "im.message.receive_v1",
    "p2p_chat_create"
  ],
  "codex_guardrails": [
    "Use the current lark-cli configuration and existing app/user authorization.",
    "Do not add Open Platform permissions, request new scopes, publish app versions, or change event subscriptions unless the user explicitly asks for that administrative change.",
    "Bridge replies must use lark-cli --as bot.",
    "For exact formatting or Chinese text, send plain UTF-8 text instead of markdown conversion unless rich rendering is explicitly needed.",
    "If the task requires a capability that is not available under the current app policy, report the limitation instead of attempting an authorization workaround."
  ]
}
